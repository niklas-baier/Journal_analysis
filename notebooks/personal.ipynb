    "def load_markdown_to_dataframe_safe(directory_path):\n",
    "    file_paths = glob.glob(os.path.join(directory_path, '*.md'))\n",
    "    data = []\n",
    "\n",
    "    for file_path in file_paths:\n",
    "        with open(file_path, 'r', encoding='utf-8') as f:\n",
    "            try:\n",
    "                # Try to parse the file\n",
    "                post = frontmatter.load(f)\n",
    "                \n",
    "                row_data = post.metadata.copy()\n",
    "                row_data['content'] = post.content\n",
    "                row_data['filename'] = os.path.basename(file_path)\n",
    "                \n",
    "                data.append(row_data)\n",
    "                \n",
    "            except yaml.scanner.ScannerError as e:\n",
    "                # If the YAML is broken, catch the error and tell us which file it is\n",
