    "            val.endswith(r\"\\end{columns}\") or\n",
    "            val.endswith(r\"\\\\\") or \n",
    "            val.endswith(\"}\")):\n",
    "            return f\"\\\\textbf{{{label}:}} {val}\\n\\n\"\n",
    "        \n",
    "        return f\"\\\\textbf{{{label}:}} {val}\\\\\\\\\\n\\n\"\n",
    "\n",
