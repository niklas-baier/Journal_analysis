    "import os\n",
    "import json\n",
    "from typing import Any, List, Dict\n",
    "\n",
    "import pandas as pd\n",
    "import psycopg\n",
    "from pydantic import BaseModel, Field\n",
    "from tqdm import tqdm\n",
    "\n",
    "# --- LangChain Core & Prompts ---\n",
    "from langchain_core.documents import Document\n",
    "from langchain_core.messages import HumanMessage, AIMessage\n",
    "from langchain_core.prompts import ChatPromptTemplate, MessagesPlaceholder\n",
    "\n",
    "# --- Ollama ---\n",
    "from langchain_ollama import OllamaLLM, OllamaEmbeddings\n",
    "\n",
    "# --- Modern Postgres Vector Store ---\n",
    "# requires: pip install langchain-postgres psycopg[binary]\n",
    "from langchain_postgres import PGVectorStore, PGEngine, PGVectorTranslator\n",
    "\n",
    "# --- Modern Chains & Retrievers ---\n",
    "from langchain_classic.retrievers.self_query.base import SelfQueryRetriever\n",
    "from langchain_classic.chains.query_constructor.schema import AttributeInfo\n",
    "from langchain_classic.chains import create_history_aware_retriever, create_retrieval_chain\n",
    "from langchain_classic.chains.combine_documents import create_stuff_documents_chain\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 0. Config\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "# Note: Modern langchain_postgres standardizes on psycopg (v3), using +psycopg instead of +psycopg2\n",
    "CONNECTION_STRING = os.getenv(\n",
    "    \"PGVECTOR_CONNECTION_STRING\",\n",
    "    \"postgresql+psycopg://user:pass@localhost:5432/journal_db\",\n",
    ")\n",
    "COLLECTION_NAME = \"journal_entries\"\n",
    "EMBED_MODEL     = \"nomic-embed-text\"\n",
    "LLM_MODEL        = \"deepseek-r1:7b\"\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 1. Pydantic schema\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "class DiarySection(BaseModel):\n",
    "    section_title: str = Field(..., description=\"Short descriptive title.\")\n",
    "    topic_summary: str = Field(..., description=\"Complete self-contained summary paragraph.\")\n",
    "    keywords: List[str] = Field(..., description=\"3-5 core keywords including proper nouns.\")\n",
    "\n",
    "class SectionsList(BaseModel):\n",
    "    sections: List[DiarySection]\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 2. Chunking\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "_llm = OllamaLLM(model=LLM_MODEL, temperature=0.1)\n",
    "\n",
    "_SYSTEM = (\n",
    "    \"You are an expert diary analyst and multilingual data extraction agent. \"\n",
    "    \"Input may be in English, German, or French with possible spelling errors. \"\n",
    "    \"\\n\\nRules:\\n\"\n",
    "    \"1. All output (summaries, keywords) MUST be in English.\\n\"\n",
    "    \"2. Silently correct spelling/grammar; standardise proper nouns to their \"\n",
    "    \"most frequent correct form.\\n\"\n",
    "    \"3. Each summary must stand alone — include WHO, WHAT, WHERE, WHEN, WHY.\\n\"\n",
    "    \"4. Preserve exact numbers, measurements, quotes.\\n\"\n",
    "    \"5. Replace ambiguous pronouns (he/she) with the person's actual name.\\n\"\n",
    "    \"6. Output ONLY valid JSON — no preamble, no markdown fences.\"\n",
    ")\n",
    "\n",
    "def _chunk_entry(text: str) -> List[DiarySection]:\n",
    "    schema = SectionsList.model_json_schema()\n",
    "    prompt = (\n",
    "        f\"{_SYSTEM}\\n\\nJSON schema to follow:\\n{json.dumps(schema)}\\n\\n\"\n",
    "        f\"---DIARY ENTRY---\\n{text}\\n---END ENTRY---\"\n",
    "    )\n",
    "    try:\n",
    "        raw = _llm.invoke(prompt)\n",
    "        \n",
    "        # Robustly strip markdown code fences even with variable spacing\n",
    "        clean = raw.strip()\n",
    "        if clean.startswith(\"```json\"):\n",
    "            clean = clean[7:]\n",
    "        elif clean.startswith(\"```\"):\n",
    "            clean = clean[3:]\n",
    "        if clean.endswith(\"```\"):\n",
    "            clean = clean[:-3]\n",
    "            \n",
    "        clean = clean.strip()\n",
    "        return SectionsList.model_validate_json(clean).sections\n",
    "    except Exception as e:\n",
    "        print(f\"  [chunking error] {e}\")\n",
    "        return []\n",
    "\n",
    "def df_to_documents(df: pd.DataFrame,\n",
    "                    content_col: str = \"content\",\n",
    "                    date_col:    str = \"date\") -> List[Document]:\n",
    "    docs: List[Document] = []\n",
    "\n",
    "    for _, row in tqdm(df.iterrows(), total=len(df), desc=\"Chunking\"):\n",
    "        text = str(row[content_col])\n",
    "        date = str(row[date_col]) if date_col in df.columns else \"unknown\"\n",
    "        sections = _chunk_entry(text)\n",
    "\n",
    "        for i, sec in enumerate(sections):\n",
    "            docs.append(Document(\n",
    "                page_content=sec.topic_summary,\n",
    "                metadata={\n",
    "                    \"date\":          date,\n",
    "                    \"section_title\": sec.section_title,\n",
    "                    \"keywords\":      \", \".join(sec.keywords),\n",
    "                    \"chunk_index\":   i,\n",
    "                    \"original_entry\": text,\n",
    "                },\n",
    "            ))\n",
    "\n",
    "    print(f\"\\nTotal documents created: {len(docs)}\")\n",
    "    return docs\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 3. Embed + store in PostgreSQL (pgvector via langchain_postgres)\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "def ingest(df: pd.DataFrame,\n",
    "           content_col: str = \"content\",\n",
    "           date_col:    str = \"date\",\n",
    "           reset: bool  = False) -> PGVectorStore:\n",
    "    \"\"\"Full ingestion: DataFrame -> chunk -> embed -> store in modern Postgres table.\"\"\"\n",
    "    \n",
    "    if reset:\n",
    "        print(f\"Wiping existing table '{COLLECTION_NAME}'...\")\n",
    "        # Clean the string for core psycopg connection if drivers prefix is kept\n",
    "        raw_conn_str = CONNECTION_STRING.replace(\"+psycopg\", \"\")\n",
    "        with psycopg.connect(raw_conn_str) as conn:\n",
    "            with conn.cursor() as cur:\n",
    "                cur.execute(f\"DROP TABLE IF EXISTS {COLLECTION_NAME};\")\n",
    "\n",
    "    docs       = df_to_documents(df, content_col, date_col)\n",
    "    embeddings = OllamaEmbeddings(model=EMBED_MODEL)\n",
    "    engine     = PGEngine.from_connection_string(url=CONNECTION_STRING)\n",
    "\n",
    "    # Initialize and populate the modern vector store directly\n",
    "    vs = PGVectorStore.from_documents(\n",
    "        documents=docs,\n",
    "        embedding=embeddings,\n",
    "        engine=engine,\n",
    "        table_name=COLLECTION_NAME,\n",
    "    )\n",
    "    print(\"Ingestion complete — vectorstore ready.\")\n",
    "    return vs\n",
    "\n",
    "\n",
    "def load_vectorstore() -> PGVectorStore:\n",
    "    \"\"\"Load without re-ingesting using sync creation utility.\"\"\"\n",
    "    engine = PGEngine.from_connection_string(url=CONNECTION_STRING)\n",
    "    return PGVectorStore.create_sync(\n",
    "        engine=engine,\n",
    "        table_name=COLLECTION_NAME,\n",
    "        embedding_service=OllamaEmbeddings(model=EMBED_MODEL),\n",
    "    )\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 4. Retriever (SelfQuery API with updated vectorstore translator)\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "_METADATA_FIELDS = [\n",
    "    AttributeInfo(\n",
    "        name=\"date\",\n",
    "        description=\"ISO date of the journal entry, e.g. '2025-12-14'. Use for range queries.\",\n",
    "        type=\"string\",\n",
    "    ),\n",
    "    AttributeInfo(\n",
    "        name=\"keywords\",\n",
    "        description=\"Comma-separated names, places, or themes.\",\n",
    "        type=\"string\",\n",
    "    ),\n",
    "    AttributeInfo(\n",
    "        name=\"section_title\",\n",
    "        description=\"Short summary title of the entry chunk.\",\n",
    "        type=\"string\",\n",
    "    ),\n",
    "]\n",
    "\n",
    "_DOC_DESCRIPTION = \"Self-contained English summaries of topics from a personal journal.\"\n",
    "\n",
    "\n",
    "def make_retriever(vs: PGVectorStore, use_self_query: bool = True, k: int = 5):\n",
    "    if not use_self_query:\n",
    "        return vs.as_retriever(search_kwargs={\"k\": k})\n",
    "\n",
    "    filter_llm = OllamaLLM(model=LLM_MODEL, temperature=0)\n",
    "    return SelfQueryRetriever.from_llm(\n",
    "        llm=filter_llm,\n",
    "        vectorstore=vs,\n",
    "        document_contents=_DOC_DESCRIPTION,\n",
    "        metadata_field_info=_METADATA_FIELDS,\n",
    "        structured_query_translator=PGVectorTranslator(),  # Force compatibility with modern backend\n",
    "        search_kwargs={\"k\": k},\n",
    "        verbose=True,\n",
    "    )\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 5. Modern Conversational QA Chain (LCEL implementation)\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "def make_chain(retriever):\n",
    "    \"\"\"Builds a modern contextual retrieval chain using stateless LCEL helpers.\"\"\"\n",
    "    chat_llm = OllamaLLM(model=LLM_MODEL, temperature=0.2)\n",
    "    \n",
    "    # Step A: Rephrase follow-ups based on conversational state\n",
    "    contextualize_q_system_prompt = (\n",
    "        \"Given a chat history and the latest user question \"\n",
    "        \"which might reference context in the chat history, \"\n",
    "        \"formulate a standalone question which can be understood \"\n",
    "        \"without the chat history. Do NOT answer the question, \"\n",
    "        \"just reformulate it if needed and otherwise return it as is.\"\n",
    "    )\n",
    "    contextualize_q_prompt = ChatPromptTemplate.from_messages([\n",
    "        (\"system\", contextualize_q_system_prompt),\n",
    "        MessagesPlaceholder(\"chat_history\"),\n",
    "        (\"human\", \"{input}\"),\n",
    "    ])\n",
    "    history_aware_retriever = create_history_aware_retriever(\n",
    "        chat_llm, retriever, contextualize_q_prompt\n",
    "    )\n",
    "    \n",
    "    # Step B: Synthesize final response from context\n",
    "    system_prompt = (\n",
    "        \"You are an expert diary analyst and multilingual data extraction agent.\\n\"\n",
    "        \"Answer the user's question using exclusively the provided context below.\\n\\n\"\n",
    "        \"Context:\\n{context}\"\n",
    "    )\n",
    "    qa_prompt = ChatPromptTemplate.from_messages([\n",
    "        (\"system\", system_prompt),\n",
    "        MessagesPlaceholder(\"chat_history\"),\n",
    "        (\"human\", \"{input}\"),\n",
    "    ])\n",
    "    \n",
    "    qa_chain = create_stuff_documents_chain(chat_llm, qa_prompt)\n",
    "    convo_chain = create_retrieval_chain(history_aware_retriever, qa_chain)\n",
    "    \n",
    "    # Dynamically inject an internal list placeholder to mimic stateful tracking\n",
    "    convo_chain.chat_history = []\n",
    "    return convo_chain\n",
    "\n",
    "\n",
    "def ask(chain, question: str) -> Dict[str, Any]:\n",
    "    \"\"\"Submits query to the LCEL chain, managing history window explicitly.\"\"\"\n",
    "    history = chain.chat_history\n",
    "    \n",
    "    # Call modern chain via required standard keys: 'input', 'chat_history'\n",
    "    result = chain.invoke({\"input\": question, \"chat_history\": history})\n",
    "    answer = result[\"answer\"]\n",
    "    \n",
    "    # Update stateful conversation tracking array\n",
    "    history.append(HumanMessage(content=question))\n",
    "    history.append(AIMessage(content=answer))\n",
    "    \n",
    "    # Maintain sliding memory footprint (keep last 6 full turns)\n",
    "    if len(history) > 12:\n",
    "        chain.chat_history = history[-12:]\n",
    "        \n",
    "    sources = [\n",
    "        {\n",
    "            \"date\":  doc.metadata.get(\"date\", \"?\"),\n",
    "            \"title\": doc.metadata.get(\"section_title\", \"?\"),\n",
    "            \"excerpt\": doc.page_content[:200],\n",
    "        }\n",
    "        for doc in result.get(\"context\", []) # Modern returns docs in 'context' key\n",
    "    ]\n",
    "    return {\"answer\": answer, \"sources\": sources}\n",
    "\n",
    "\n",
    "# ---------------------------------------------------------------------------\n",
    "# 6. Convenience wrapper & Driver\n",
    "# ---------------------------------------------------------------------------\n",
    "\n",
    "def build_query_engine(df: pd.DataFrame = None,\n",
    "                       content_col: str  = \"content\",\n",
    "                       date_col: str     = \"date\",\n",
    "                       use_self_query: bool = True,\n",
    "                       k: int = 5,\n",
    "                       reset: bool = False):\n",
    "    if df is not None:\n",
    "        vs = ingest(df, content_col, date_col, reset=reset)\n",
    "    else:\n",
    "        vs = load_vectorstore()\n",
    "\n",
    "    retriever = make_retriever(vs, use_self_query=use_self_query, k=k)\n",
    "    return make_chain(retriever)\n",
    "\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    df = pd.DataFrame({\n",
    "        \"date\": [\"2025-12-14\", \"2025-12-15\", \"2025-12-16\"],\n",
    "        \"content\": [\n",
    "            \"Woke up early, watched the news. The city council voted down the park \"\n",
    "            \"proposal, very frustrating. Spent three hours rewriting the docs for the \"\n",
    "            \"Authentication module at work. Dinner was chicken and rice.\",\n",
    "\n",
    "            \"Great day! Finished the Auth docs early. Went hiking, weather was perfect. \"\n",
    "            \"Met Tom and discussed the budget for the new app — he seemed hesitant about \"\n",
    "            \"the timeline. Got a call from my mother, she's doing fine.\",\n",
    "\n",
    "            \"The cat was sick, took her to the vet (cost 150 EUR). Very stressful. \"\n",
    "            \"Team meeting: data migration is moving slowly. Tried a new coffee shop, \"\n",
    "            \"the latte was excellent.\",\n",
    "        ],\n",
    "    })\n",
    "\n",
    "    print(\"=== First run: ingesting and querying ===\")\n",
    "    chain = build_query_engine(df=df, reset=True)\n",
    "\n",
    "    questions = [\n",
    "        \"When did I mention Tom and what did we discuss?\",\n",
    "        \"What happened the next day?\",  # Tests context memory rephrasing\n",
    "        \"Which entries mention work or documentation?\",\n",
    "        \"How much did the vet visit cost?\",\n",
    "    ]\n",
    "\n",
    "    for q in questions:\n",
    "        print(f\"\\nQ: {q}\")\n",
    "        r = ask(chain, q)\n",
    "        print(f\"A: {r['answer']}\")\n",
    "        for s in r[\"sources\"]:\n",
    "            print(f\"   [{s['date']}] {s['title']}\")\n",
    "            print(f\"   {s['excerpt']}...\")"
