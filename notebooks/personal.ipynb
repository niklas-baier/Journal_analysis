    "    [12.01, 9.49, np.nan],\n",
    "    [12.35, 9.19, 10],\n",
    "    [12.22, 9.04, 8],\n",
    "    [12.06, 8.28, 8.5],\n",
    "    [12.47, 9.01, 8.5],\n",
    "    [1.35, 9.22, 9],\n",
    "    [1.47, 9.29, 8],\n",
    "    [1.53, 8.4, 7.5],\n",
    "    [1.5, 10.24, 9],\n",
    "    [1.02, np.nan, np.nan],\n",
