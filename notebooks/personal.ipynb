    "import pandas as pd\n",
    "import re\n",
    "\n",
    "def extract_and_remove(pattern, target_col):\n",
    "    \"\"\"\n",
    "    Decorator that:\n",
    "    1. Extracts a regex pattern from df['content']\n",
    "    2. Passes that raw string to your parsing function\n",
    "    3. Saves the parsed result to df[target_col]\n",
    "    4. Removes the matched pattern from df['content']\n",
    "    \"\"\"\n",
    "    def decorator(parser_func):\n",
    "        def wrapper(df, source_col='content'):\n",
    "            # 1. Extract the raw text block. \n",
    "            \n",
    "            raw_blocks = df[source_col].str.extract(pattern, flags=re.DOTALL)[0]\n",
    "            \n",
    "            # 2. Parse the block (ignoring rows where the section wasn't found)\n",
    "            df[target_col] = raw_blocks.apply(\n",
    "                lambda text: parser_func(text) if pd.notna(text) else None\n",
    "            )\n",
    "            \n",
    "            # 3. Remove the entire matched block from the original content column\n",
    "            df[source_col] = df[source_col].str.replace(pattern, '', regex=True, flags=re.DOTALL)\n",
    "            \n",
    "            # Optional: Clean up random double-newlines \n",
    "            df[source_col] = df[source_col].str.replace(r'\\n{3,}', '\\n\\n', regex=True).str.strip()\n",
    "            \n",
    "            return df\n",
    "        return wrapper\n",
    "    return decorator\n",
    "# --- 1. ACTIVITIES ---\n",
    "@extract_and_remove(pattern=r'(```mermaid.*?```)', target_col='activities')\n",
    "def parse_mermaid(block):\n",
    "    matches = re.findall(r'\"([^\"]+)\"\\s*:\\s*([\\d.]+)', block)\n",
    "    return {activity: float(value) for activity, value in matches}\n",
    "\n",
    "# --- 2. TODOS ---\n",
    "@extract_and_remove(pattern=r'(## ✅ TODOS\\n.*?(?=\\n## |\\Z))', target_col='todos')\n",
    "def parse_todos(block):\n",
    "    # Regex finds '- [ ]' or '- [x]' and captures the text after it\n",
    "    tasks = re.findall(r'- \\[[ xX]\\] (.*)', block)\n",
    "    return [task.strip() for task in tasks]\n",
    "\n",
    "# --- 3. FUNNY ---\n",
    "@extract_and_remove(pattern=r'(## 😂 Funny\\n.*?(?=\\n## |\\Z))', target_col='funny')\n",
    "def parse_funny(block):\n",
    "    # We just want the text, so let's strip out the heading itself\n",
    "    clean_text = re.sub(r'^## 😂 Funny\\n', '', block).strip()\n",
    "    return clean_text"
   ]
