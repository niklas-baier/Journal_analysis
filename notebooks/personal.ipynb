    "\n",
    "def intensive_gpu_clean():\n",
    "    # 1. Clear out Python's references\n",
    "    gc.collect()\n",
    "    \n",
    "    # 2. Clear the CUDA cache\n",
    "    if torch.cuda.is_available():\n",
    "        torch.cuda.empty_cache()\n",
    "        \n",
